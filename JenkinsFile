pipeline {
    agent any
    
    environment {
        // Linode VPS Configuration
        LINODE_HOST = '172.236.21.79'
        LINODE_USER = 'root'
        CONTAINER_NAME = 'nodejs-app'
        HOST_PORT = '3000'
        CONTAINER_PORT = '3000'
        // Your GitHub repo
        GIT_REPO = 'https://github.com/PetxCode/watchAA.git'
        GIT_BRANCH = 'main'
    }
    
    stages {
        stage('Checkout Source Code') {
            steps {
                git branch: GIT_BRANCH, url: GIT_REPO
                echo '✅ Code checked out successfully from GitHub'
            }
        }
        
        stage('Verify Package.json Exists') {
            steps {
                script {
                    // Check if package.json exists
                    if (fileExists('package.json')) {
                        echo '✅ package.json found!'
                        sh 'cat package.json'
                    } else {
                        error '❌ package.json not found! Make sure your repo has the Node.js app files.'
                    }
                }
            }
        }
        
        stage('Build Docker Image') {
            steps {
                script {
                    echo '📦 Building Docker image...'
                    sh """
                        docker build -t ${CONTAINER_NAME}:latest .
                        docker images | grep ${CONTAINER_NAME}
                    """
                }
            }
        }
        
        stage('Save Docker Image') {
            steps {
                script {
                    echo '💾 Saving Docker image to tar file...'
                    sh """
                        docker save ${CONTAINER_NAME}:latest -o ${CONTAINER_NAME}.tar
                        ls -lh ${CONTAINER_NAME}.tar
                    """
                }
            }
        }
        
        stage('Transfer and Deploy to Linode') {
            steps {
                script {
                    echo '🚀 Transferring image to Linode VPS...'
                    // Using sshpass for password authentication
                    sh """
                        # Install sshpass if not available
                        command -v sshpass || sudo apt-get install -y sshpass
                        
                        # Copy Docker image to Linode
                        sshpass -p 'Peter#445' scp -o StrictHostKeyChecking=no ${CONTAINER_NAME}.tar ${LINODE_USER}@${LINODE_HOST}:/tmp/
                        
                        echo '📦 Deploying container on Linode...'
                        # Deploy on Linode
                        sshpass -p 'Peter#445' ssh -o StrictHostKeyChecking=no ${LINODE_USER}@${LINODE_HOST} << 'ENDSSH'
                            echo "Loading Docker image..."
                            docker load -i /tmp/${CONTAINER_NAME}.tar
                            
                            echo "Stopping old container..."
                            docker stop ${CONTAINER_NAME} 2>/dev/null || true
                            docker rm ${CONTAINER_NAME} 2>/dev/null || true
                            
                            echo "Starting new container..."
                            docker run -d \
                                --name ${CONTAINER_NAME} \
                                -p ${HOST_PORT}:${CONTAINER_PORT} \
                                --restart unless-stopped \
                                ${CONTAINER_NAME}:latest
                            
                            echo "Cleaning up..."
                            rm /tmp/${CONTAINER_NAME}.tar
                            
                            echo "Container status:"
                            docker ps | grep ${CONTAINER_NAME}
                            
                            echo "Testing application..."
                            sleep 3
                            curl -s http://localhost:${HOST_PORT} || echo "Container is running but not yet responding"
                        ENDSSH
                        
                        # Clean up local tar file
                        rm ${CONTAINER_NAME}.tar
                    """
                }
            }
        }
        
        stage('Verify Deployment') {
            steps {
                script {
                    echo '🔍 Verifying deployment...'
                    sh """
                        sshpass -p 'Peter#445' ssh -o StrictHostKeyChecking=no ${LINODE_USER}@${LINODE_HOST} << 'ENDSSH'
                            echo "✅ Container logs:"
                            docker logs --tail 20 ${CONTAINER_NAME}
                        ENDSSH
                    """
                }
            }
        }
    }
    
    post {
        success {
            echo """
            ╔══════════════════════════════════════════════════════════╗
            ║                                                          ║
            ║  🎉 DEPLOYMENT SUCCESSFUL! 🎉                            ║
            ║                                                          ║
            ║  Your Node.js app is now LIVE at:                        ║
            ║  🔗 http://${LINODE_HOST}:${HOST_PORT}                   ║
            ║                                                          ║
            ║  To view real-time logs:                                 ║
            ║  ssh root@${LINODE_HOST} 'docker logs -f ${CONTAINER_NAME}' ║
            ║                                                          ║
            ║  To restart the container:                               ║
            ║  ssh root@${LINODE_HOST} 'docker restart ${CONTAINER_NAME}' ║
            ║                                                          ║
            ╚══════════════════════════════════════════════════════════╝
            """
        }
        failure {
            echo """
            ╔══════════════════════════════════════════════════════════╗
            ║  ❌ DEPLOYMENT FAILED!                                   ║
            ║                                                          ║
            ║  Check the console output above for errors.              ║
            ║                                                          ║
            ║  Common issues:                                          ║
            ║  - Docker not installed on Linode                        ║
            ║  - Port 3000 blocked by firewall                         ║
            ║  - Missing package.json or Dockerfile                    ║
            ║  - Incorrect password                                    ║
            ╚══════════════════════════════════════════════════════════╝
            """
        }
        always {
            // Clean up any remaining files
            sh 'rm -f nodejs-app.tar || true'
        }
    }
}